(defwindow conky-doom
  :monitor 0
  :geometry (geometry :x "84%"
                      :y "10%"
                      :width "15%"
                      :height "45%"
                      :anchor "top left")
  :stacking "bottom"
  ; :reserve (struts :distance "0px" :side "top")
  :windowtype "dock"
  :wm-ignore false

  (box :class "conky"
  :orientation "v"
  :valign "start" :halign "center" :space-evenly "false" :vexpand "true" :hexpand "true"

      (box :class "date-time"
      :orientation "v"
      :valign "center" :halign "center" :space-evenly "true" :vexpand "true" :hexpand "true"

          (box :class "time-doom"
          :orientation "h"
          :spacing 0
          :valign "start" :halign "center" :space-evenly "false" :vexpand "false" :hexpand "false" 
          :height "40px"
            (Time))

          (box :class "date-doom"
          :orientation "h"
          :spacing 0
          :valign "start" :halign "center" :space-evenly "false" :vexpand "false" :hexpand "false"
          :height "40px"
            (Date))
          
      )
      (box :class "info"
      :orientation "v"
      :valign "center" :space-evenly "true" :vexpand "true" :hexpand "true"
          (box :class "kernel"
          :orientation "h"
          :spacing 0
          :valign "start" :space-evenly "true" :vexpand "false" :hexpand "false" 
          ; :height "40px"
            (kernel-label-doom)
            (kernel-doom))
          (box :class "uptime"
          :orientation "h"
          :spacing 0
          :valign "start" :space-evenly "true" :vexpand "false" :hexpand "false" 
          ; :height "40px"
            (uptime-label-doom)
            (uptime-doom))
          (box :class "date"
          :orientation "h"
          :spacing 0
          :valign "start" :space-evenly "true" :vexpand "false" :hexpand "false" 
          ; :height "40px"
            (disk-label-doom)
            (disk-doom))
      )
      (spacing)
      (box :class "keys-box"
      :orientation "v"
      :valign "center" :halign "center" :space-evenly "false" :vexpand "true" :hexpand "true"
            ; (ram)
            ; (ram-scale)
            ; (cpu)
            ; (cpu-scale)
            ; (spacing)
            (keys-title)
            (separator)
            (box :class "keys1"
            :orientation "h"
            ; :spacing 2
            ; :valign "start" :halign "center" :space-evenly "false" :vexpand "false" :hexpand "false"
            ; :height "40px"
              (keys1-left)
              (keys1-right))
            (separator)
            (box :class "keys2"
            :orientation "h"
            ; :spacing 2
            ; :valign "start" :halign "center" :space-evenly "false" :vexpand "false" :hexpand "false"
            ; :height "40px"
              (keys2-left)
              (keys2-right))
            (separator)
            (box :class "keys3"
            :orientation "h"
            ; :spacing 2
            ; :valign "start" :halign "center" :space-evenly "false" :vexpand "false" :hexpand "false"
            ; :height "40px"
              (keys3-left)
              (keys3-right))
            (spacing)
        )
))
    

(defwindow conky-powerline
  :monitor 0
  :geometry (geometry :x "84%"
                      :y "10%"
                      :width "15%"
                      :height "45%"
                      :anchor "top left")
  :stacking "bottom"
  ; :reserve (struts :distance "0px" :side "top")
  :windowtype "dock"
  :wm-ignore false

  (box :class "conky"
  :orientation "v"
  :valign "start" :halign "center" :space-evenly "false" :vexpand "true" :hexpand "true"

      (box :class "date-time"
      :orientation "v"
      :valign "center" :halign "center" :space-evenly "true" :vexpand "true" :hexpand "true"

          (box :class "time-powerline"
          :orientation "h"
          :spacing 0
          :valign "start" :halign "center" :space-evenly "false" :vexpand "false" :hexpand "false" 
          :height "40px"
            (Time))

          (box :class "date-powerline"
          :orientation "h"
          :spacing 0
          :valign "start" :halign "center" :space-evenly "false" :vexpand "false" :hexpand "false"
          :height "40px"
            (Date))
          
      )
      (box :class "info"
      :orientation "v"
      :valign "center" :space-evenly "true" :vexpand "true" :hexpand "true"
          (box :class "kernel"
          :orientation "h"
          :spacing 0
          :valign "start" :space-evenly "true" :vexpand "false" :hexpand "false" 
          ; :height "40px"
            (kernel-label)
            (kernel))
          (box :class "uptime"
          :orientation "h"
          :spacing 0
          :valign "start" :space-evenly "true" :vexpand "false" :hexpand "false" 
          ; :height "40px"
            (uptime-label)
            (uptime))
          (box :class "date"
          :orientation "h"
          :spacing 0
          :valign "start" :space-evenly "true" :vexpand "false" :hexpand "false" 
          ; :height "40px"
            (disk-label)
            (disk))
      )
      (spacing)
      (box :class "keys-box"
      :orientation "v"
      :valign "center" :halign "center" :space-evenly "false" :vexpand "true" :hexpand "true"
            ; (ram)
            ; (ram-scale)
            ; (cpu)
            ; (cpu-scale)
            ; (spacing)
            (keys-title)
            (separator)
            (box :class "keys1"
            :orientation "h"
            ; :spacing 2
            ; :valign "start" :halign "center" :space-evenly "false" :vexpand "false" :hexpand "false"
            ; :height "40px"
              (keys1-left)
              (keys1-right))
            (separator)
            (box :class "keys2"
            :orientation "h"
            ; :spacing 2
            ; :valign "start" :halign "center" :space-evenly "false" :vexpand "false" :hexpand "false"
            ; :height "40px"
              (keys2-left)
              (keys2-right))
            (separator)
            (box :class "keys3"
            :orientation "h"
            ; :spacing 2
            ; :valign "start" :halign "center" :space-evenly "false" :vexpand "false" :hexpand "false"
            ; :height "40px"
              (keys3-left)
              (keys3-right))
            (spacing)
        )
))

;(defpoll time)
;(defpoll date)
;(defpoll cpu)
;(defpoll ram)
;(defpoll fullram)
; (defwidget )
(defwidget separator []
  (label
    :text "------------------------------------------------"
    ; :yalign 0
    :xalign 0.5
  )
)
(defwidget spacing []
  (label
    :text " "
    :yalign 0
    :xalign 0.5
  )
)

(defwidget Time []
  (box :orientation "h" 
       :class "time"
       :halign "center"
     timechk))

(defwidget Date []
  (box :orientation "h" 
       :class "date"
       :halign "center" 
     day))

(defpoll timechk :interval "1s" "date '+%H:%M'")

; (defpoll day_word :interval "10m" "date +%a | tr [:upper:] [:lower:]")
(defpoll day      :interval "1s" "date '+%d %B %Y'")
; (defpoll month    :interval "1h"  "date +%m")
; (defpoll year     :interval "1h"  "date +%y")
(defpoll kernelchk      :interval "1s" "uname -r | cut -d '-' -f1")
(defpoll uptimechk      :interval "1s" "uptime | awk -F, '{sub(\".*up \",x,$1)\;print $1}' | sed -e 's/^[ \\t]*//'")
;
; Disk check: all the bells and whistles
; (defpoll diskchk        :interval "1s" "df -H | grep -vE '^Filesystem|tmpfs|cdrom' | awk '{ print $6 \" : \" $3 \"/\" $2 \"(\" $5 \")\" }' | grep \"/ \"")
; Disk check: Percentage
