    :text "Kernel:"
    :class "Infolabel"
    ; :yalign 0
    :xalign 0.5
  )
)

(defwidget uptime-label []
  (label
    :text "Uptime:"
    :class "Infolabel"
    ; :yalign 0
    :xalign 0.5
  )
)

(defwidget disk-label []
  (label
    :text "Disk:"
    :class "Infolabel"
    ; :yalign 0
    :xalign 0.5
  )
)

(defwidget kernel []
  (box :orientation "h" 
       :class "kernel"
       :halign "center" 
     kernelchk)
)

(defwidget uptime []
  (box :orientation "h" 
       :class "uptime"
       :halign "center" 
     uptimechk)
)

(defwidget disk []
  (box :orientation "h" 
       :class "disk"
       :halign "center" 
     diskchk)
)

