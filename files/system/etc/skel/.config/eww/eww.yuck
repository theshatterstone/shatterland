(defwidget keys-title []
  (label
    :text "KEYBINDINGS"
    :class "keys-title"
    ; :yalign 0
    :xalign 0.5
  )
)

(defwidget keys1-left []
  (label
    :text "
     [S] + RETURN
     [S] + W
     [S] + SHIFT + RET
     [S] + R
     [S] + P
     [S] + SHIFT + C"
     :class "keys1-left"
    ; :yalign 0
    :xalign 0
  )
)

(defwidget keys1-right []
  (label
    :text "
    Open Terminal 
    Open Browser 
    Open File Manager 
    Open Run launcher 
    Open Drun launch 
    Close Win "
    :class "keys1-right"
    ; :yalign 0
    :xalign 0
  )
)

(defwidget keys2-left []
  (label
    :text "
     [S] + j/k
     [S] + SHIFT + hjkl
     [S] + 1-9
     [S] + SHIFT + 1-9
     [S] + h/l
     [S] + Space"
     :class "keys2-left"
    ; :yalign 0
    :xalign 0
  )
)

(defwidget keys2-right []
  (label
    :text "
    Move Win Focus 
    Move Window 
    Switch Workspace 
    Send Window 
    shrink/expand
    Swap to Master"
    :class "keys2-right"
    ; :yalign 0
    :xalign 0
  )
)

(defwidget keys3-left []
  (label
    :text "
     [S] + SHIFT + R
     [S] + SHIFT + Q"
