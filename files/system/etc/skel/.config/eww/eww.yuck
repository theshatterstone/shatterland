; Disk check: Numbers (RECOMMENDED)
(defpoll diskchk        :interval "1s" "df -H | grep -vE '^Filesystem|tmpfs|cdrom' | awk '{ print $6 \" : \" $3 \"/\" $2 }' | grep \"/ \" | cut -d : -f 2")


